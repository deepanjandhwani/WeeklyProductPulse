# ─────────────────────────────────────────────────────────────────────────────
# WeeklyProductPulse — Environment Variables
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API Key (free tier) — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (free tier) — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: model id (default gemini-2.0-flash). Switch if free-tier quota is exhausted for one model.
# GEMINI_MODEL=gemini-2.0-flash-lite

# ── Optional Overrides ────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL  (default: INFO)
LOG_LEVEL=INFO

# Max reviews to fetch per week scrape (default: 1000 — increase if needed)
MAX_REVIEWS_PER_WEEK=1000

# Phase 3: false = quote LLM must succeed for all themes or no insights file (use with --no-fallback)
PHASE3_ALLOW_FALLBACK=true
# Phase 3 quote selection: groq (default, same as Phase 2) | gemini
# PHASE3_QUOTE_LLM=groq
# Optional Groq model for Phase 3 only (defaults to GROQ_MODEL in config.py)
# PHASE3_GROQ_MODEL=llama-3.3-70b-versatile

# Phase 4 weekly pulse: groq (default) | gemini
# PHASE4_REPORT_LLM=groq
# PHASE4_GROQ_MODEL=llama-3.3-70b-versatile

# Phase 4 fee block (curated prompts/fee_scenarios.json — exactly one scenario; no LLM)
# FEE_SECTION_ENABLED=true
# FEE_SCENARIO_ID=exit_load_mf   # optional: must match the id in fee_scenarios.json if set

# Google Docs (optional): append weekly run to a Doc — see docs/GOOGLE_DOCS.md
# GOOGLE_DOCS_APPEND_ENABLED=false
# GOOGLE_DOCS_DOCUMENT_ID=your_document_id_from_url
#
# Transport: direct = Python Google API + service account (GOOGLE_APPLICATION_CREDENTIALS)
#            mcp    = spawn @a-bonus/google-docs-mcp (GOOGLE_CLIENT_ID/SECRET + npx auth token)
# GOOGLE_DOCS_APPEND_TRANSPORT=direct
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Cursor MCP + pipeline MCP append: @a-bonus/google-docs-mcp (OAuth Desktop — same env for both)
# Create OAuth client (Desktop app) in Google Cloud; enable Docs + Sheets + Drive APIs; add yourself as test user.
# Then run once: npx -y @a-bonus/google-docs-mcp auth
# GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...

# Phase 2 reduce: llm = Groq merges raw tags → canonical themes (Option B); fuzzy = RapidFuzz only
THEME_MERGE_MODE=llm

# Max unique raw tags sent to the merge LLM (default: 100); tail tags get nearest-canonical assignment
THEME_MERGE_MAX_UNIQUE_TAGS=100

# ── Web dashboard + email (optional) — see docs/WEB_DASHBOARD.md ────────────────
# Run: uvicorn web.main:app --host 127.0.0.1 --port 8080
# SMTP_* + EMAIL_RECIPIENTS required to send mail from the UI or POST /api/email/send
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=app-specific-password
# SMTP_FROM=Weekly Pulse <you@gmail.com>
# SMTP_USE_TLS=true
# Default recipients when POST /api/email/send omits "recipients" (UI always sends explicit emails)
# EMAIL_RECIPIENTS=pm@company.com,analytics@company.com
# Optional: protect email API — browser prompt or curl -H "X-Pulse-API-Token: ..."
# PULSE_WEB_API_TOKEN=
# Auto-send after `python -m scheduler` completes (requires SMTP configured)
# EMAIL_REPORT_AFTER_PIPELINE=false
