FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY requirements-app.txt ./
RUN pip install --upgrade pip && pip install -r requirements-app.txt

COPY . .

RUN mkdir -p data/reports && \
    cp -n demo/2026-W12_pulse.md data/reports/ 2>/dev/null || true

EXPOSE 7860

CMD ["uvicorn", "web.main:app", "--host", "0.0.0.0", "--port", "7860"]
