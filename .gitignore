# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Node (Next.js at repo root / workspaces) ─────────────────────────────────
node_modules/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Secrets — NEVER commit these ──────────────────────────────────────────────
.env

# ── Data files — excluded from git (can be large) ────────────────────────────
data/cache/
data/consolidated/
data/tagged/
data/reports/*.json
# Pulse Markdown reports are committed by CI so they survive on diskless hosts
!data/reports/*_pulse.md

# ── Log files ─────────────────────────────────────────────────────────────────
logs/

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store

# ── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── pytest ────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
